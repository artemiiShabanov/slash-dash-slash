[resource]
default_font = ExtResource("1_fontui")
default_font_size = 16

; ===== Label =====
Label/colors/font_color = Color(0.96, 0.97, 0.92, 1)

; ===== Button =====
Button/colors/font_color = Color(0.96, 0.97, 0.92, 1)
Button/colors/font_hover_color = Color(0.96, 0.97, 0.92, 1)
Button/colors/font_pressed_color = Color(0.07, 0.06, 0.05, 1)
Button/colors/font_disabled_color = Color(0.45, 0.42, 0.38, 1)
Button/styles/normal = SubResource("sb_btn_normal")
Button/styles/hover = SubResource("sb_btn_hover")
Button/styles/pressed = SubResource("sb_btn_pressed")
Button/styles/disabled = SubResource("sb_btn_disabled")

; ===== Panel / PanelContainer =====
Panel/styles/panel = SubResource("sb_panel")
PanelContainer/styles/panel = SubResource("sb_panel")

; ===== Document type variation (paper-on-dark, breaks the inverted scheme on purpose) =====
PanelContainer/Document/base_type = "PanelContainer"
PanelContainer/Document/styles/panel = SubResource("sb_panel_document")

; ===== RichTextLabel =====
RichTextLabel/colors/default_color = Color(0.96, 0.97, 0.92, 1)
RichTextLabel/Document/base_type = "RichTextLabel"
RichTextLabel/Document/colors/default_color = Color(0.07, 0.06, 0.05, 1)
RichTextLabel/Document/fonts/normal_font = ExtResource("2_fontdoc")

; ===== LineEdit (already terminal-style; preserved) =====
LineEdit/colors/font_color = Color(0.34, 0.78, 0.42, 1)
LineEdit/colors/caret_color = Color(0.34, 0.78, 0.42, 1)
LineEdit/colors/selection_color = Color(0.34, 0.78, 0.42, 0.35)
LineEdit/styles/normal = SubResource("sb_lineedit")
LineEdit/styles/focus = SubResource("sb_lineedit")

; ===== Containers =====
HBoxContainer/constants/separation = 4
VBoxContainer/constants/separation = 4

; ===== Separators =====
HSeparator/constants/separation = 4
VSeparator/constants/separation = 4
HSeparator/colors/separator_color = Color(0.45, 0.42, 0.38, 1)
VSeparator/colors/separator_color = Color(0.45, 0.42, 0.38, 1)

; ===== ProgressBar =====
ProgressBar/colors/font_color = Color(0.96, 0.97, 0.92, 1)
ProgressBar/styles/background = SubResource("sb_progress_bg")
ProgressBar/styles/fill = SubResource("sb_progress_fill")

; ===== ScrollBar =====
HScrollBar/styles/scroll = SubResource("sb_scroll_track")
HScrollBar/styles/grabber = SubResource("sb_scroll_grabber")
VScrollBar/styles/scroll = SubResource("sb_scroll_track")
VScrollBar/styles/grabber = SubResource("sb_scroll_grabber")

; ===== CheckBox =====
