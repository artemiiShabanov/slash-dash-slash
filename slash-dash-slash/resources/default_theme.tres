[ext_resource type="FontFile" path="res://assets/fonts/font_document.ttf" id="2_fontdoc"]

; Default project Theme.
;
; Inverted-CRT scheme: dark backgrounds, bright text, dot-matrix-green accents
; on hover/borders, solid-green "selected" state on pressed buttons. Mimics a
; 1970s monochrome terminal.
;
; Default font: VT323 (terminal/CRT) — drives all in-game UI.
; Document variation font: Special Elite (typewriter) — used by the Document
; type_variation on RichTextLabel and PanelContainer for paper-styled surfaces.
;
; The `Document` type variation breaks the inverted-CRT scheme on purpose —
; paper documents (resignation form, memos, in-world notes) render as
; dark-ink-on-paper-yellow for diegetic contrast.
;
; Colors are hardcoded snapshots of `palette.tres` defaults — keep in sync
; manually when tuning the palette.
;
; Palette references (hardcoded):
;   paper_yellow      = Color(0.96, 0.91, 0.74)
;   bone_white        = Color(0.92, 0.89, 0.81)
;   ink_black         = Color(0.07, 0.06, 0.05)
;   fluorescent_white = Color(0.96, 0.97, 0.92)
;   shadow_grey       = Color(0.45, 0.42, 0.38)
;   dot_matrix_green  = Color(0.34, 0.78, 0.42)
;   blood_red         = Color(0.65, 0.16, 0.13)
;   boardroom_black   = Color(0.10, 0.09, 0.10)

; ===== StyleBoxes =====

